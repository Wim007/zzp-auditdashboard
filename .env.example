# Database
DATABASE_URL="postgresql://user:password@localhost:5432/veiligheidsdashboard"

# Auth
NEXTAUTH_SECRET="vervang-dit-met-een-lang-willekeurig-geheim"
NEXTAUTH_URL="http://localhost:3000"

# Data adapter: 'mock' of 'apm'
DATA_ADAPTER="mock"

# APM integratie (alleen nodig als DATA_ADAPTER=apm)
